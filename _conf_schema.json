{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "trigger_word": {
            "type": "string",
            "description": "触发词",
            "default": "/agreement"
        },
        "agree_word": {
            "type": "string",
            "description": "同意词",
            "default": "同意"
        },
        "disagree_word": {
            "type": "string",
            "description": "拒绝词",
            "default": "不同意"
        },
        "agreement_content": {
            "type": "string",
            "description": "协议内容（支持多行文本）",
            "default": "欢迎使用本服务。\n\n请仔细阅读以下协议：\n1. 遵守相关规定\n2. 禁止滥用\n\n回复「同意」即表示接受。",
            "format": "textarea"
        },
        "agree_reply": {
            "type": "string",
            "description": "同意后的回复",
            "default": "您已同意协议，感谢您的配合！"
        },
        "disagree_reply": {
            "type": "string",
            "description": "拒绝后的回复（留空则不回复）",
            "default": ""
        },
        "already_agreed_reply": {
            "type": "string",
            "description": "已经同意过的回复",
            "default": "您已经同意过协议了，无需重复签订。"
        }
    }
}
