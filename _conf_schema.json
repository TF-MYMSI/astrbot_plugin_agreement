{
    "admins": {
        "type": "list",
        "items": {"type": "string"},
        "default": []
    },
    "scope_private": {
        "type": "bool",
        "default": true
    },
    "scope_group": {
        "type": "bool",
        "default": false
    },
    "doc_name": {
        "type": "string",
        "default": "用户协议"
    },
    "doc_version": {
        "type": "string",
        "default": "v1.0"
    },
    "doc_updated": {
        "type": "string",
        "default": "2026-04-09"
    },
    "doc_contact": {
        "type": "string",
        "default": "QQ群 000000000"
    },
    "trigger_keywords": {
        "type": "list",
        "items": {"type": "string"},
        "default": ["协议", "规则", "条例"]
    },
    "agree_keywords": {
        "type": "list",
        "items": {"type": "string"},
        "default": ["同意", "agree", "YES", "是", "接受"]
    },
    "refuse_keywords": {
        "type": "list",
        "items": {"type": "string"},
        "default": ["不同意", "disagree", "NO", "否", "拒绝"]
    },
    "cooldown_seconds": {
        "type": "int",
        "default": 30
    },
    "delivery_text": {
        "type": "bool",
        "default": true
    },
    "reply_agree": {
        "type": "string",
        "default": "✅ 已记录你的同意。现在可以正常使用本机器人。"
    },
    "reply_refuse": {
        "type": "string",
        "default": "❌ 已记录你的拒绝。本机器人将无法为你服务。"
    },
    "reply_waiting": {
        "type": "string",
        "default": "📝 请回复「同意」或「不同意」接受{name}。"
    },
    "doc_sections": {
        "type": "list",
        "items": {
            "type": "object",
            "properties": {
                "title": {"type": "string"},
                "content": {"type": "string"}
            }
        },
        "default": []
    },
    "allow_undo": {
        "type": "bool",
        "default": true
    },
    "max_undo": {
        "type": "int",
        "default": 3
    },
    "undo_cooldown": {
        "type": "int",
        "default": 86400
    }
}
